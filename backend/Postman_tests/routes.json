          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"securepassword123\",\n  \"recaptchaResponse\": \"mock-recaptcha-token\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/signup"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Successful signup\", function () {",
              "    pm.response.to.have.status(200);",
              "    var jsonData = pm.response.json();",
              "    pm.collectionVariables.set(\"token\", jsonData.access_token);",
              "    pm.collectionVariables.set(\"user_id\", jsonData.user_id);",
              "});"
            ],
            "type": "text/javascript"
          }
