{
  "info": {
    "name": "Unlockino User Entity API Tests",
    "description": "Pipeline test for user_entity_api.py endpoints. Assumes user is logged in from previous collection. Chains create, get, update, delete entity.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Entity",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"url\": \"http://example.com\",\n  \"university\": \"Test University\",\n  \"location\": {},\n  \"website\": \"http://test.com\",\n  \"edurank\": {},\n  \"department\": {},\n  \"publications\": {},\n  \"related\": \"Test related\",\n  \"point_of_contact\": {},\n  \"scopes\": [\"scope1\"],\n  \"research_abstract\": \"Test abstract\",\n  \"lab_equipment\": {},\n  \"climate_tech_focus\": [\"renewable\"],\n  \"climate_impact_metrics\": {},\n  \"embeddings\": {},\n  \"images\": [\n    {\n      \"url\": \"http://image.com\",\n  \"caption\": \"Test caption\",\n      \"is_primary\": true\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/user_entities/"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Entity created\", function () {",
              "    pm.response.to.have.status(200);",
              "    var jsonData = pm.response.json();",
              "    pm.collectionVariables.set(\"entity_id\", jsonData.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Entities",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/user_entities/?skip=0&limit=50"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Entities retrieved\", function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Specific Entity",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/user_entities/{{entity_id}}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Entity retrieved\", function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Update Entity",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"university\": \"Updated University\",\n  \"research_abstract\": \"Updated abstract\",\n  \"climate_tech_focus\": [\"updated_focus\"],\n  \"images\": [\n    {\n      \"url\": \"http://updatedimage.com\",\n  \"caption\": \"Updated caption\",\n      \"is_primary\": false\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/user_entities/{{entity_id}}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Entity updated\", function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Delete Entity",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/user_entities/{{entity_id}}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Entity deleted\", function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "entity_id",
      "value": "",
      "type": "string"
    }
  ]
}