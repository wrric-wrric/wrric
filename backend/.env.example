# WRRIC Backend Environment Variables
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/wrric

# For sync operations (Alembic migrations)
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wrric

# ═══════════════════════════════════════════════════════════════
# AUTHENTICATION
# ═══════════════════════════════════════════════════════════════
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# ═══════════════════════════════════════════════════════════════
# OAUTH - GOOGLE (Optional - only if using Google login)
# ═══════════════════════════════════════════════════════════════
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ═══════════════════════════════════════════════════════════════
# OAUTH - LINKEDIN (Optional - only if using LinkedIn login)
# ═══════════════════════════════════════════════════════════════
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/auth/linkedin/callback

# ═══════════════════════════════════════════════════════════════
# EMAIL (SMTP) - Optional
# ═══════════════════════════════════════════════════════════════
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM_NAME=WRRIC Platform
EMAIL_FROM_ADDRESS=noreply@wrric.com

# ═══════════════════════════════════════════════════════════════
# AI/LLM APIs (Optional - for enhanced features)
# ═══════════════════════════════════════════════════════════════
GROQ_API_KEY=
GOOGLE_API_KEY=

# ═══════════════════════════════════════════════════════════════
# CLOUD STORAGE - Backblaze B2 (Optional - for file uploads)
# ═══════════════════════════════════════════════════════════════
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_BUCKET_ID=

# ═══════════════════════════════════════════════════════════════
# FRONTEND & CORS
# ═══════════════════════════════════════════════════════════════
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# ═══════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════
DEBUG=true
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
